# Wallet Balance Assistant — Backend Environment Variables

# Serveur
PORT=8080
ENVIRONMENT=development

# Base de données (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Authentification (Clerk)
CLERK_SECRET_KEY=sk_test_xxx

# Chiffrement tokens bancaires (32 bytes = 64 hex chars)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Enable Banking — Open Banking Europe
# Créer un compte sur https://enablebanking.com/
# Application ID : UUID fourni dans le dashboard Enable Banking
ENABLE_BANKING_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Clé RSA privée PEM (PKCS8 ou PKCS1) — les \n doivent être littéraux sur une seule ligne
# Exemple : -----BEGIN PRIVATE KEY-----\nMIIEvg...\n-----END PRIVATE KEY-----
ENABLE_BANKING_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nVOTRE_CLE_ICI\n-----END PRIVATE KEY-----

# Cron job authentication
CRON_KEY=your-cron-key-here

# URL de l'app (pour les redirections après connexion bancaire)
APP_URL=http://localhost:8081
