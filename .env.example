# ─── Frontend (Expo) ───────────────────────────────────────────────────────────
# Clerk publishable key (visible côté client)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL du backend API
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# ─── Backend Only (NE JAMAIS COMMITTER le .env réel) ──────────────────────────
# Clerk secret key — à récupérer sur dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL de la base de données PostgreSQL (Neon, Supabase, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Clé secrète pour les jobs cron GitHub Actions
CRON_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Clé de chiffrement AES-256 pour les tokens bancaires (32 bytes en hex)
ENCRYPTION_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
